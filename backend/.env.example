# Mirra Backend — Environment Variables
# Copy to .env and fill in values

# Perfect Corp
PERFECT_CORP_API_KEY=
PERFECT_CORP_BASE_URL=https://yce-api-01.makeupar.com

# Vertex AI Gemini (Publisher) — GCP project + credentials (pick one auth method)
GCP_PROJECT_ID=

GCP_SERVICE_ACCOUNT_JSON=

# Serper (Google Shopping)
SERPER_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
PRODUCT_IMAGE_STORAGE_BUCKET=resolved-product-images

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Calendar (optional — falls back to mock events)
GOOGLE_CALENDAR_CREDENTIALS=

# App
PORT=8000
CORS_ORIGIN=http://localhost:3000,https://your-frontend-domain.vercel.app
