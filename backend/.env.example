# Mirra Backend — Environment Variables
# Copy to .env and fill in values

# Perfect Corp
PERFECT_CORP_API_KEY=
PERFECT_CORP_BASE_URL=https://yce-api-01.makeupar.com

# Deepgram
DEEPGRAM_API_KEY=

# Google AI Studio (Gemini 3.1 Pro)
GOOGLE_AI_STUDIO_KEY=

# Serper (Google Shopping)
SERPER_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379/0

# Google Calendar (optional — falls back to mock events)
GOOGLE_CALENDAR_CREDENTIALS=

# App
USE_MOCKS=true
PORT=8000
CORS_ORIGIN=http://localhost:3000
